<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 
      Gemini maps "Add expense" to CREATE_MONEY_TRANSFER or CREATE_NOTE.
      We provide BOTH App-Function and Intent fallback.
    -->
    
    <capability android:name="actions.intent.CREATE_MONEY_TRANSFER">
        <app-function android:name="com.sandeep.personalfinancecompanion.appfunctions.FinanceAppFunctions#addExpense">
            <parameter android:name="amount" android:key="amount" />
            <parameter android:name="category" android:key="category" />
            <parameter android:name="notes" android:key="notes" />
        </app-function>
        <!-- Fallback for Gemini if App Functions are not native on this OS version -->
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.sandeep.personalfinancecompanion"
            android:targetClass="com.sandeep.personalfinancecompanion.MainActivity">
            <parameter android:name="amount" android:key="amount" />
            <parameter android:name="notes" android:key="notes" />
        </intent>
    </capability>

    <capability android:name="actions.intent.CREATE_NOTE">
        <app-function android:name="com.sandeep.personalfinancecompanion.appfunctions.FinanceAppFunctions#addExpense">
            <parameter android:name="notes" android:key="notes" />
        </app-function>
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.sandeep.personalfinancecompanion"
            android:targetClass="com.sandeep.personalfinancecompanion.MainActivity">
            <parameter android:name="notes" android:key="notes" />
        </intent>
    </capability>

    <capability android:name="actions.intent.GET_FINANCE_ACCOUNT">
        <app-function android:name="com.sandeep.personalfinancecompanion.appfunctions.FinanceAppFunctions#addIncome" />
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.sandeep.personalfinancecompanion"
            android:targetClass="com.sandeep.personalfinancecompanion.MainActivity" />
    </capability>
</shortcuts>
